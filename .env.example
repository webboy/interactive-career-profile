APP_ENV=local
APP_NAME="Interactive Career Profile"
APP_URL=http://localhost:9000
API_URL=http://localhost:8000
MCP_URL=http://mcp:8100
MCP_INTERNAL_API_TOKEN=change-me-mcp-internal-token
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
ADMIN_NOTIFICATION_EMAIL=admin@example.com
SMTP_TIMEOUT_SECONDS=10
DATABASE_URL=postgresql+psycopg://icp:icp@postgres:5432/icp
SESSION_SECRET=change-me-session-secret
JWT_SECRET=change-me-jwt-secret
AUTH_COOKIE_NAME=icp_admin_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_TOKEN_EXPIRES_MINUTES=10080
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de,sr
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AGENT_MAX_TOKENS=1024
AGENT_TEMPERATURE=0.2
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
RETRIEVAL_STRUCTURED_LIMIT=10
RETRIEVAL_DOCUMENT_LIMIT=5
RETRIEVAL_DOCUMENT_SCORE_THRESHOLD=0.7
FILESYSTEM_DRIVER=local
LOCAL_STORAGE_PATH=./storage/uploads
DOCUMENT_UPLOAD_MAX_BYTES=10485760
DOCUMENT_CHUNK_SIZE_CHARS=1200
DOCUMENT_CHUNK_OVERLAP_CHARS=200
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=
S3_PUBLIC_URL=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@localhost
SMTP_FROM_NAME="Interactive Career Profile"
SMTP_USE_TLS=false
ENABLE_DEMO_SEED=false
